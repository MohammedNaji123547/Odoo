<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── LIST VIEW ─── -->
    <record id="view_invoice_request_list" model="ir.ui.view">
        <field name="name">invoice.request.list</field>
        <field name="model">invoice.request</field>
        <field name="arch" type="xml">
            <tree string="Invoice Requests"
                  decoration-info="state == 'draft'"
                  decoration-muted="state == 'in_review'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'finance_approved'"
                  decoration-danger="state in ('rejected', 'cancelled')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="partner_id"/>
                <field name="contract_id"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="requester_id"/>
                <field name="total_amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'finance_approved'"
                       decoration-danger="state in ('rejected', 'cancelled')"/>
            </tree>
        </field>
    </record>

    <!-- ─── FORM VIEW ─── -->
    <record id="view_invoice_request_form" model="ir.ui.view">
        <field name="name">invoice.request.form</field>
        <field name="model">invoice.request</field>
        <field name="arch" type="xml">
            <form string="Invoice Request">
                <header>
                    <!-- DRAFT -->
                    <button name="action_submit" string="Submit for Approval"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>

                    <!-- IN REVIEW: Current approver actions (user-specific) -->
                    <button name="action_approver_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="not is_current_approver"/>
                    <button name="action_approver_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="not is_current_approver"/>
                    <button name="action_approver_resubmit" string="Resubmit to Requester"
                            type="object"
                            invisible="not is_current_approver"/>

                    <!-- PENDING FINANCE: Finance actions -->
                    <button name="action_finance_approve" string="Approve &amp; Create Bill"
                            type="object" class="btn-success"
                            invisible="state != 'submitted'"
                            groups="invoice_request.group_finance"/>
                    <button name="action_finance_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="invoice_request.group_finance"/>
                    <button name="action_finance_resubmit" string="Resubmit to Requester"
                            type="object"
                            invisible="state != 'submitted'"
                            groups="invoice_request.group_finance"/>

                    <!-- REJECTED / CANCELLED: Reset -->
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected', 'cancelled')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_review,submitted,finance_approved"/>
                </header>

                <sheet>
                    <!-- invisible fields for domains / logic -->
                    <field name="partner_id" invisible="1"/>
                    <field name="analytic_account_id" invisible="1"/>
                    <field name="project_id" invisible="1"/>
                    <field name="is_current_approver" invisible="1"/>
                    <field name="current_approver_id" invisible="1"/>

                    <!-- Smart button: linked vendor bill -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_bill" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="not vendor_bill_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Vendor Bill</span>
                                <span class="o_stat_value">
                                    <field name="bill_state" widget="badge"
                                           decoration-warning="bill_state == 'not_paid'"
                                           decoration-success="bill_state == 'paid'"
                                           decoration-info="bill_state == 'partial'"/>
                                </span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Request Details">
                            <field name="requester_id" readonly="1"/>
                            <field name="request_date" readonly="1"/>
                            <field name="invoice_date" readonly="state != 'draft'"/>
                            <field name="period_from" readonly="state != 'draft'"/>
                            <field name="period_to" readonly="state != 'draft'"/>
                        </group>
                        <group string="Vendor &amp; Contract">
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="contract_id"
                                   domain="[('partner_id', '=', partner_id), ('state', 'in', ['active', 'completed']), ('contract_type', '!=', 'frame_msa')]"
                                   readonly="state != 'draft'"/>
                            <field name="analytic_account_id"
                                   readonly="1"/>
                            <field name="project_id"
                                   readonly="1"/>
                            <field name="currency_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <!-- Approval info -->
                    <group string="Approval Information"
                           invisible="state == 'draft'">
                        <field name="finance_user_id" readonly="1"
                               invisible="not finance_user_id"/>
                        <field name="vendor_bill_id" readonly="1"
                               invisible="not vendor_bill_id"/>
                        <field name="rejection_reason" readonly="1"
                               invisible="not rejection_reason"/>
                    </group>

                    <!-- Payment Summary (inline, above lines) -->
                    <div invisible="not contract_id">
                        <separator string="Payment Summary"/>
                        <field name="payment_summary_html" readonly="1"/>
                    </div>

                    <!-- 2-column: notebook left, timeline right -->
                    <div style="display:flex; align-items:flex-start; gap:0; margin-top:4px;">

                        <!-- LEFT: notebook -->
                        <div style="flex:1; min-width:0;">
                            <notebook>
                                <!-- ── Invoice Lines ── -->
                                <page string="Invoice Lines">
                                    <field name="line_ids" readonly="state != 'draft'">
                                        <tree editable="bottom"
                                              decoration-warning="has_approved_co == True">
                                            <field name="sequence" widget="handle"/>
                                            <field name="contract_line_id" invisible="1" force_save="1"/>
                                            <field name="has_approved_co" invisible="1"/>
                                            <field name="description" readonly="1" force_save="1"/>
                                            <field name="uom" readonly="1" force_save="1" string="Unit"/>
                                            <field name="qty" readonly="1" force_save="1"
                                                   string="Current QTY"/>
                                            <field name="unit_price" readonly="1" force_save="1"
                                                   string="Current Rate"/>
                                            <field name="contract_amount" readonly="1"
                                                   string="Current Amount"/>
                                            <field name="completed_qty"/>
                                            <field name="remaining_qty" readonly="1"/>
                                            <field name="billing_amount" readonly="1"/>
                                            <field name="co_tag" readonly="1"
                                                   string="CO"
                                                   optional="show"
                                                   decoration-warning="co_tag != False"/>
                                        </tree>
                                    </field>
                                    <group class="oe_subtotal_footer oe_right">
                                        <field name="total_amount"
                                               string="Total Billing Amount" readonly="1"
                                               widget="monetary"/>
                                    </group>
                                </page>

                                <!-- ── Approvers ── -->
                                <page string="Approvers">
                                    <field name="approver_ids" readonly="state != 'draft'">
                                        <tree editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="user_id"/>
                                            <field name="status" widget="badge"
                                                   decoration-success="status == 'approved'"
                                                   decoration-danger="status == 'rejected'"
                                                   decoration-warning="status == 'pending'"/>
                                        </tree>
                                    </field>
                                </page>

                                <!-- ── Attachments ── -->
                                <page string="Attachments">
                                    <field name="attachment_ids"
                                           widget="many2many_binary"
                                           readonly="state != 'draft'"/>
                                </page>

                                <!-- ── Notes ── -->
                                <page string="Notes">
                                    <field name="notes"
                                           placeholder="Add justification or notes for Finance..."
                                           readonly="state != 'draft'"/>
                                </page>
                            </notebook>
                        </div>

                        <!-- RIGHT: Workflow Timeline -->
                        <div style="flex:0 0 280px; width:280px; margin-left:16px;
                                    border-left:2px solid #f0f0f0; padding-left:16px;
                                    padding-top:12px;">
                            <div style="font-size:11px; font-weight:700; color:#8c96a5;
                                        text-transform:uppercase; letter-spacing:.7px;
                                        margin-bottom:14px; padding-bottom:8px;
                                        border-bottom:1px solid #f0f0f0;">
                                <i class="fa fa-history" style="margin-right:5px;"></i>
                                Workflow History
                            </div>
                            <field name="timeline_html" readonly="1"/>
                        </div>

                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── SEARCH VIEW ─── -->
    <record id="view_invoice_request_search" model="ir.ui.view">
        <field name="name">invoice.request.search</field>
        <field name="model">invoice.request</field>
        <field name="arch" type="xml">
            <search string="Search Invoice Requests">
                <field name="name" string="Request No."/>
                <field name="partner_id"/>
                <field name="contract_id"/>
                <field name="requester_id"/>
                <filter string="My Requests" name="my_requests"
                        domain="[('requester_id', '=', uid)]"/>
                <filter string="In Review" name="in_review"
                        domain="[('state', '=', 'in_review')]"/>
                <filter string="Submitted" name="submitted"
                        domain="[('state', '=', 'submitted')]"/>
                <filter string="Pending Manager" name="pending_manager"
                        domain="[('state', '=', 'submitted')]"/>
                <filter string="Pending Finance" name="pending_finance"
                        domain="[('state', '=', 'manager_approved')]"/>
                <filter string="Finance Approved" name="approved"
                        domain="[('state', '=', 'finance_approved')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Vendor" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Requester" name="group_requester"
                            context="{'group_by': 'requester_id'}"/>
                    <filter string="Contract" name="group_contract"
                            context="{'group_by': 'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── KANBAN VIEW ─── -->
    <record id="view_invoice_request_kanban" model="ir.ui.view">
        <field name="name">invoice.request.kanban</field>
        <field name="model">invoice.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="requester_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="partner_id"/>
                                    </small>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted">
                                    <field name="requester_id"
                                           widget="many2one_avatar_user"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="total_amount" widget="monetary"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── ACTION ─── -->
    <record id="action_invoice_request" model="ir.actions.act_window">
        <field name="name">Invoice Requests</field>
        <field name="res_model">invoice.request</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_invoice_request_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>
</odoo>
