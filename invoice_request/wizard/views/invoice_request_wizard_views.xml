<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_request_wizard_form" model="ir.ui.view">
        <field name="name">invoice.request.wizard.form</field>
        <field name="model">invoice.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Provide Reason">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="action_code" invisible="1"/>
                    <field name="reason" placeholder="Enter reason..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
