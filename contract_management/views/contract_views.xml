<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LIST VIEW -->
    <record id="view_contract_list" model="ir.ui.view">
        <field name="name">contract.contract.list</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <tree string="Contracts"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('completed','cancelled')">
                <field name="name"/>
                <field name="title"/>
                <field name="contract_type"/>
                <field name="responsible_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="value"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('review','rfq_processing','evaluation','pending_approval','finalization')"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'cancelled'"
                       decoration-muted="state == 'completed'"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_contract_form" model="ir.ui.view">
        <field name="name">contract.contract.form</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <form string="Contract">
                <header>
                    <!-- DRAFT -->
                    <button name="action_submit_review" string="Submit for Review"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- UNDER REVIEW -->
                    <button name="action_reviewed" string="Reviewed"
                            type="object" class="btn-primary"
                            invisible="state != 'review'"
                            groups="contract_management.group_subcontractor_team"/>
                    <button name="action_resubmit_requestor" string="Resubmit to Requestor"
                            type="object"
                            invisible="state != 'review'"
                            groups="contract_management.group_subcontractor_team"/>

                    <!-- RFQ PROCESSING -->
                    <button name="action_rfq_proceed" string="Proceed"
                            type="object" class="btn-primary"
                            invisible="state != 'rfq_processing'"
                            groups="contract_management.group_subcontractor_team"/>
                    <button name="action_rfq_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            invisible="state != 'rfq_processing'"
                            groups="contract_management.group_subcontractor_team"/>

                    <!-- EVALUATION -->
                    <button name="action_proceed_approval" string="Proceed for Approval"
                            type="object" class="btn-primary"
                            invisible="state != 'evaluation'"
                            groups="contract_management.group_subcontractor_team"/>
                    <button name="action_evaluation_resubmit_requestor"
                            string="Resubmit to Requestor"
                            type="object"
                            invisible="state != 'evaluation'"
                            groups="contract_management.group_subcontractor_team"/>
                    <button name="action_evaluation_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            invisible="state != 'evaluation'"
                            groups="contract_management.group_subcontractor_team"/>

                    <!-- PENDING APPROVAL: Sequential approver actions -->
                    <button name="action_approver_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="not is_current_approver"/>
                    <button name="action_approver_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="not is_current_approver"/>
                    <button name="action_approver_resubmit_contracting"
                            string="Resubmit to Contracting"
                            type="object"
                            invisible="not is_current_approver or contract_type == 'unit_rate_ctr'"/>
                    <button name="action_approver_resubmit_requester"
                            string="Resubmit to Requester"
                            type="object"
                            invisible="not is_current_approver"/>

                    <!-- FINALIZATION -->
                    <button name="action_finalization_proceed" string="Proceed"
                            type="object" class="btn-success"
                            invisible="state != 'finalization'"
                            groups="contract_management.group_subcontractor_team"/>
                    <button name="action_finalization_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            invisible="state != 'finalization'"
                            groups="contract_management.group_subcontractor_team"/>

                    <!-- ACTIVE -->
                    <button name="action_active_proceed" string="Proceed"
                            type="object" class="btn-primary"
                            invisible="state != 'active'"
                            groups="contract_management.group_subcontractor_team"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,rfq_processing,evaluation,pending_approval,finalization,active,completed"/>
                </header>

                <sheet>
                    <!-- Smart button: Change Orders -->
                    <div class="oe_button_box" name="button_box"
                         invisible="contract_type not in ('lump_sum_ctr', 'unit_rate_ctr')">
                        <button name="%(contract_management.action_change_order_by_contract)d"
                                type="action" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="change_order_count" widget="statinfo"
                                   string="Change Orders"/>
                        </button>
                    </div>

                    <!-- invisible fields used in domains / logic -->
                    <field name="evaluated_partner_ids" invisible="1"/>
                    <field name="partner_id" invisible="1"/>
                    <field name="is_current_approver" invisible="1"/>
                    <field name="current_approver_id" invisible="1"/>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h2>
                            <field name="title" placeholder="Contract Title..."
                                   readonly="state in ('review','rfq_processing')"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Contract Details">
                            <field name="contract_type"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="contractor_id"
                                   invisible="contract_type != 'unit_rate_ctr'"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="parent_frame_id"
                                   invisible="contract_type != 'unit_rate_ctr'"
                                   readonly="state in ('review','rfq_processing')"
                                   domain="[('contract_type','=','frame_msa'),('state','in',['active','completed']),('partner_id','=',contractor_id)]"/>
                            <field name="responsible_id" readonly="1"/>
                            <field name="analytic_account_id"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="project_id"
                                   readonly="state in ('review','rfq_processing')"/>
                        </group>
                        <group string="Dates &amp; Value">
                            <field name="start_date"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="end_date"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="currency_id"
                                   readonly="state in ('review','rfq_processing')"/>
                            <field name="value"
                                   readonly="(contract_type not in ('frame_msa','daywork_tm') and state not in ('finalization','active','completed')) or state in ('review','rfq_processing')"/>
                        </group>
                    </group>

                    <!-- 2-column: notebook left, timeline right -->
                    <div style="display:flex; align-items:flex-start; gap:0; margin-top:4px;">

                        <!-- LEFT: notebook -->
                        <div style="flex:1; min-width:0;">
                            <notebook>
                                <page string="Description">
                                    <field name="description"
                                           placeholder="Contract scope and description..."
                                           readonly="state in ('review','rfq_processing')"/>
                                </page>

                                <!-- WORK ITEMS -->
                                <page string="Work Items">
                                    <field name="line_ids"
                                           readonly="state in ('review','rfq_processing')">
                                        <tree editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="description"/>
                                            <field name="qty"
                                                   column_invisible="parent.contract_type in ('frame_msa','daywork_tm')"/>
                                            <field name="uom"/>
                                            <field name="unit_price"
                                                string="Agreed Rate"
                                                column_invisible="parent.contract_type in ('daywork_tm','lump_sum_ctr') and parent.state not in ('finalization','active','completed')"
                                                readonly="parent.contract_type == 'unit_rate_ctr'"
                                                force_save="1"/>
                                            <field name="subtotal"
                                                column_invisible="parent.contract_type in ('frame_msa','daywork_tm','lump_sum_ctr')"
                                                readonly="1"/>
                                        </tree>
                                    </field>
                                    <group class="oe_subtotal_footer oe_right"
                                           invisible="contract_type in ('frame_msa','daywork_tm','lump_sum_ctr')">
                                        <field name="lines_total" string="Lines Total" readonly="1"/>
                                    </group>
                                </page>

                                <!-- BOQ / DOCUMENTS -->
                                <page string="BOQ &amp; Documents">
                                    <field name="attachment_ids" widget="many2many_binary"
                                           readonly="state in ('review','rfq_processing')"/>
                                </page>

                                <!-- APPROVAL CHAIN -->
                                <page string="Approval Chain">
                                    <p class="text-muted"
                                       invisible="state in ('pending_approval','finalization','active','completed')">
                                        Add approvers here — they will be notified sequentially
                                        when this contract reaches Pending Approval.
                                    </p>
                                    <field name="approver_ids"
                                           readonly="state in ('pending_approval','finalization','active','completed')">
                                        <tree editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="user_id"/>
                                            <field name="status" widget="badge"
                                                   decoration-success="status == 'approved'"
                                                   decoration-danger="status == 'rejected'"
                                                   decoration-warning="status == 'pending'"/>
                                        </tree>
                                    </field>
                                </page>

                                <!-- COMMERCIAL EVALUATION -->
                                <page string="Commercial Evaluation"
                                      invisible="state not in ('evaluation','pending_approval','finalization','active','completed') or contract_type == 'unit_rate_ctr'">
                                    <field name="evaluation_ids">
                                        <tree decoration-success="is_lowest"
                                              decoration-info="is_recommended">
                                            <field name="partner_id" string="Contractor"/>
                                            <field name="total_amount" string="Total Amount"/>
                                            <field name="avg_profitability" string="Avg. Profit %"/>
                                            <field name="is_recommended" widget="boolean"/>
                                            <field name="is_lowest" widget="boolean"/>
                                            <field name="notes"/>
                                        </tree>
                                    </field>
                                    <separator string="Side-by-Side Comparison"/>
                                    <field name="eval_comparison_html" readonly="1"/>
                                </page>

                                <!-- FINALIZATION -->
                                <page string="Finalization"
                                      invisible="state not in ('finalization','active','completed')">
                                    <group string="Counterparty">
                                        <field name="partner_id"
                                               string="Counterparty"
                                               domain="[('id','in',evaluated_partner_ids)] if contract_type != 'unit_rate_ctr' else []"
                                               required="state in ('finalization','active','completed')"
                                               readonly="contract_type == 'unit_rate_ctr'"/>
                                    </group>
                                    <separator string="Signed Contract Copy (Mandatory)"/>
                                    <field name="signed_copy_ids" widget="many2many_binary"/>
                                </page>

                                <!-- CHANGE ORDER HISTORY TAB -->
                                <page string="Change Order History"
                                      invisible="contract_type not in ('lump_sum_ctr', 'unit_rate_ctr')">
                                    <field name="change_order_line_ids" readonly="1">
                                        <tree decoration-success="co_state == 'approved'"
                                              decoration-warning="co_state == 'pending_approval'"
                                              decoration-danger="co_state == 'rejected'">
                                            <field name="co_name" string="Change Order No."/>
                                            <field name="co_date" string="CO Date"/>
                                            <field name="original_description" string="Work Item Name"/>
                                            <field name="original_qty" string="Original Qty"/>
                                            <field name="original_unit_price" string="Original Unit Price"/>
                                            <field name="change_type" string="Change Type"/>
                                            <field name="change_qty" string="Change Qty"
                                                   optional="show"/>
                                            <field name="new_unit_price" string="New Unit Price"
                                                   optional="show"/>
                                            <field name="revised_qty" string="Revised Qty"/>
                                            <field name="change_value" string="Change Value"
                                                   sum="Total Change Value"/>
                                            <field name="change_percentage" string="Change %"/>
                                            <field name="cumulative_change_percentage"
                                                   string="Cumulative %"
                                                   decoration-danger="cumulative_change_percentage > 20"/>
                                            <field name="co_created_by_id" string="Created By"/>
                                            <field name="co_state" string="Status"
                                                   widget="badge"
                                                   decoration-success="co_state == 'approved'"
                                                   decoration-warning="co_state == 'pending_approval'"
                                                   decoration-danger="co_state == 'rejected'"/>
                                            <field name="currency_id" invisible="1"/>
                                        </tree>
                                    </field>
                                </page>
                            </notebook>
                        </div>

                        <!-- RIGHT: Workflow Timeline -->
                        <div style="flex:0 0 280px; width:280px; margin-left:16px;
                                    border-left:2px solid #f0f0f0; padding-left:16px;
                                    padding-top:12px;">
                            <div style="font-size:11px; font-weight:700; color:#8c96a5;
                                        text-transform:uppercase; letter-spacing:.7px;
                                        margin-bottom:14px; padding-bottom:8px;
                                        border-bottom:1px solid #f0f0f0;">
                                <i class="fa fa-history" style="margin-right:5px;"></i>
                                Workflow History
                            </div>
                            <field name="timeline_html" readonly="1"/>
                        </div>

                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_contract_search" model="ir.ui.view">
        <field name="name">contract.contract.search</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="name" string="Contract No."/>
                <field name="title"/>
                <field name="partner_id"/>
                <field name="responsible_id"/>
                <filter string="My Contracts" name="my_contracts"
                        domain="[('responsible_id','=',uid)]"/>
                <filter string="Active" name="active_f" domain="[('state','=','active')]"/>
                <filter string="Pending Approval" name="pending"
                        domain="[('state','=','pending_approval')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'contract_type'}"/>
                    <filter string="Requester" name="group_resp"
                            context="{'group_by': 'responsible_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_contract_kanban" model="ir.ui.view">
        <field name="name">contract.contract.kanban</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="name"/>
                <field name="title"/>
                <field name="contract_type"/>
                <field name="responsible_id"/>
                <field name="value"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="title"/>
                                    </small>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="contract_type" widget="badge"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted">
                                    <field name="responsible_id" widget="many2one_avatar_user"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="value" widget="monetary"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- GRAPH VIEW -->
    <record id="view_contract_graph" model="ir.ui.view">
        <field name="name">contract.contract.graph</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <graph string="Contracts by Stage" type="bar" stacked="1">
                <field name="state" type="row"/>
                <field name="contract_type" type="col"/>
            </graph>
        </field>
    </record>

    <!-- PIVOT VIEW -->
    <record id="view_contract_pivot" model="ir.ui.view">
        <field name="name">contract.contract.pivot</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <pivot string="Contracts Overview">
                <field name="state" type="row"/>
                <field name="contract_type" type="col"/>
                <field name="value" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_contract_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">contract.contract</field>
        <field name="view_mode">tree,kanban,graph,pivot,form</field>
        <field name="search_view_id" ref="view_contract_search"/>
        <field name="context">{'search_default_my_contracts': 1}</field>
    </record>
</odoo>
