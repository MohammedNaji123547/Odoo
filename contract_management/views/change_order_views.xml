<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FORM VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_change_order_form" model="ir.ui.view">
        <field name="name">contract.change_order.form</field>
        <field name="model">contract.change_order</field>
        <field name="arch" type="xml">
            <form string="Change Order">
                <header>
                    <!-- Draft actions -->
                    <button name="action_submit" string="Submit for Approval"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="contract_management.group_subcontractor_team"/>

                    <!-- Approver actions -->
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="not is_current_approver"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="not is_current_approver"/>

                    <!-- Reset to draft -->
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected',)"
                            groups="contract_management.group_management"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_approval,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Hidden fields needed for domains/logic -->
                    <field name="is_current_approver" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <group>
                        <group string="Change Order Details">
                            <field name="partner_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="contract_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="contract_type" readonly="1"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="created_by_id" readonly="1"/>
                        </group>
                        <group string="Contract Reference">
                            <field name="original_contract_value" readonly="1"/>
                            <field name="total_change_value" readonly="1"/>
                            <field name="total_change_percentage" readonly="1"
                                   string="This CO Change %"/>
                            <field name="cumulative_change_percentage" readonly="1"
                                   string="Cumulative Change %"
                                   decoration-danger="cumulative_change_percentage > 20"/>
                        </group>
                    </group>

                    <group string="Reason / Justification">
                        <field name="reason" nolabel="1"
                               placeholder="Describe the reason for this change order..."
                               readonly="state != 'draft'"/>
                    </group>

                    <!-- ── Change Order History ── -->
                    <div invisible="not contract_id">
                        <div style="font-weight:700;font-size:13px;letter-spacing:.5px;
                                    text-transform:uppercase;color:#2c3e50;
                                    border-bottom:2px solid #2c3e50;
                                    padding-bottom:6px;margin:16px 0 8px 0;">
                            CHANGE ORDER HISTORY
                        </div>
                        <field name="co_history_html" readonly="1" nolabel="1"/>
                    </div>

                    <notebook>

                        <!-- CHANGE ITEMS TAB -->
                        <page string="Change Items">
                            <field name="line_ids"
                                   readonly="state != 'draft'">
                                <tree editable="bottom" decoration-muted="change_type == False">
                                    <field name="sequence" widget="handle"/>
                                    <field name="contract_line_id"
                                           string="Work Item"
                                           options="{'no_create': True}"/>
                                    <field name="original_description" readonly="1"/>
                                    <field name="original_qty" readonly="1"/>
                                    <field name="original_unit_price" readonly="1" string="Unit Price"/>
                                    <field name="original_total" readonly="1" string="Original Total"/>
                                    <field name="change_type"/>
                                    <field name="change_qty"
                                           readonly="change_type not in ('change_qty', 'change_qty_price')"/>
                                    <field name="new_unit_price"
                                           readonly="change_type not in ('change_price', 'change_qty_price')"/>
                                    <field name="revised_qty" readonly="1"/>
                                    <field name="change_value" readonly="1"/>
                                    <field name="change_percentage" readonly="1"
                                           string="Change %"/>
                                    <field name="cumulative_change_percentage" readonly="1"
                                           string="Cumulative %"
                                           decoration-danger="cumulative_change_percentage > 20"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                                <!-- Expanded line form inside the tree -->
                                <form string="Change Item">
                                    <field name="currency_id" invisible="1"/>
                                    <group>
                                        <group string="Original (Read-Only)">
                                            <field name="contract_line_id"
                                                   string="Work Item"
                                                   options="{'no_create': True}"/>
                                            <field name="original_description" readonly="1"/>
                                            <field name="original_qty" readonly="1"/>
                                            <field name="original_unit_price" readonly="1" string="Unit Price"/>
                                            <field name="original_total" readonly="1"/>
                                        </group>
                                        <group string="Change Details">
                                            <field name="change_type"/>
                                            <field name="change_qty"
                                                   invisible="change_type not in ('change_qty', 'change_qty_price')"/>
                                            <field name="new_unit_price"
                                                   invisible="change_type not in ('change_price', 'change_qty_price')"/>
                                            <field name="revised_qty" readonly="1"
                                                   invisible="change_type not in ('change_qty', 'change_qty_price')"/>
                                        </group>
                                    </group>
                                    <group string="Impact">
                                        <field name="change_value" readonly="1"/>
                                        <field name="change_percentage" readonly="1"
                                               string="Change %"/>
                                        <field name="cumulative_change_percentage" readonly="1"
                                               string="Cumulative Change %"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- APPROVAL CHAIN TAB -->
                        <page string="Approval Chain">
                            <p class="text-muted"
                               invisible="state in ('pending_approval', 'approved', 'rejected')">
                                Add approvers here — they will be notified sequentially
                                when this Change Order is submitted.
                            </p>
                            <field name="approver_ids"
                                   readonly="state in ('pending_approval', 'approved', 'rejected')">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="user_id"/>
                                    <field name="status" readonly="1"
                                           decoration-success="status == 'approved'"
                                           decoration-danger="status == 'rejected'"
                                           decoration-warning="status == 'pending'"/>
                                </tree>
                            </field>
                        </page>

                        <!-- DOCUMENTS TAB -->
                        <page string="Supporting Documents">
                            <field name="attachment_ids" widget="many2many_binary"
                                   readonly="state == 'approved'"/>
                        </page>

                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         LIST VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_change_order_list" model="ir.ui.view">
        <field name="name">contract.change_order.list</field>
        <field name="model">contract.change_order</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'approved'"
                  decoration-warning="state == 'pending_approval'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="contract_type"/>
                <field name="total_change_value" sum="Total"/>
                <field name="total_change_percentage" string="Change %"/>
                <field name="cumulative_change_percentage" string="Cumulative %"
                       decoration-danger="cumulative_change_percentage > 20"/>
                <field name="created_by_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'pending_approval'"
                       decoration-danger="state == 'rejected'"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         SEARCH VIEW
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_change_order_search" model="ir.ui.view">
        <field name="name">contract.change_order.search</field>
        <field name="model">contract.change_order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Change Order"/>
                <field name="contract_id"/>
                <field name="partner_id" string="Contractor"/>
                <separator/>
                <filter name="draft"            string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="pending_approval" string="Pending Approval"
                        domain="[('state','=','pending_approval')]"/>
                <filter name="approved"         string="Approved"
                        domain="[('state','=','approved')]"/>
                <filter name="my_approval"      string="Awaiting My Approval"
                        domain="[('current_approver_id','=',uid),('state','=','pending_approval')]"/>
                <separator/>
                <filter name="lump_sum" string="Lump Sum CTR"
                        domain="[('contract_type','=','lump_sum_ctr')]"/>
                <filter name="unit_rate" string="Unit Rate CTR"
                        domain="[('contract_type','=','unit_rate_ctr')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_contract"  string="Contract"
                            context="{'group_by': 'contract_id'}"/>
                    <filter name="group_partner"   string="Contractor"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state"     string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         ACTION
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_change_order" model="ir.actions.act_window">
        <field name="name">Change Orders</field>
        <field name="res_model">contract.change_order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_change_order_search"/>
        <field name="context">{'search_default_pending_approval': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Change Order
            </p>
            <p>
                Change Orders modify the quantity or price of work items
                on an existing Lump Sum or Unit Rate contract.
            </p>
        </field>
    </record>

    <!-- Action filtered to a specific contract (used by smart button) -->
    <record id="action_change_order_by_contract" model="ir.actions.act_window">
        <field name="name">Change Orders</field>
        <field name="res_model">contract.change_order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_change_order_search"/>
        <field name="domain">[('contract_id', '=', active_id)]</field>
        <field name="context">{'default_contract_id': active_id}</field>
    </record>

</odoo>
