<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_justification_wizard_form" model="ir.ui.view">
        <field name="name">contract.justification.wizard.form</field>
        <field name="model">contract.justification.wizard</field>
        <field name="arch" type="xml">
            <form string="Provide Justification">
                <group>
                    <field name="contract_id" readonly="1"
                           invisible="not contract_id"/>
                    <field name="co_id" readonly="1"
                           invisible="not co_id" string="Change Order"/>
                    <field name="action_label" readonly="1" string="Action"/>
                    <field name="action_code" invisible="1"/>
                    <field name="justification"
                           placeholder="Enter reason or justification..."
                           required="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>