<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Frame Agreement: IG-CN-FA-DDMMYYYY-01 -->
        <record id="seq_contract_frame_msa" model="ir.sequence">
            <field name="name">Frame Agreement</field>
            <field name="code">contract.frame_msa</field>
            <field name="prefix">IG-CN-FA-%(day)s%(month)s%(year)s-</field>
            <field name="padding">2</field>
            <field name="company_id" eval="False"/>
        </record>
        <!-- Lump Sum CTR: IG-CTR-DDMMYYYY-01 -->
        <record id="seq_contract_lump_sum_ctr" model="ir.sequence">
            <field name="name">Lump Sum CTR</field>
            <field name="code">contract.lump_sum_ctr</field>
            <field name="prefix">IG-CTR-%(day)s%(month)s%(year)s-</field>
            <field name="padding">2</field>
            <field name="company_id" eval="False"/>
        </record>
        <!-- Daywork T&M: IG-T&M-DDMMYYYY-01 -->
        <record id="seq_contract_daywork_tm" model="ir.sequence">
            <field name="name">Daywork T&amp;M CTR</field>
            <field name="code">contract.daywork_tm</field>
            <field name="prefix">IG-T&amp;M-%(day)s%(month)s%(year)s-</field>
            <field name="padding">2</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
