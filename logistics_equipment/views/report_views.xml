<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ PIVOT VIEW ════════════════════════════════════════════════════════ -->
    <record id="view_attendance_pivot" model="ir.ui.view">
        <field name="name">logistics.attendance.pivot</field>
        <field name="model">logistics.attendance</field>
        <field name="arch" type="xml">
            <pivot string="Attendance Analysis">
                <field name="equipment_id"    type="row"/>
                <field name="attendance_date" type="col" interval="month"/>
                <field name="planned_qty"     type="measure"/>
                <field name="actual_qty"      type="measure"/>
                <field name="attendance_rate" type="measure"/>
                <field name="working_hours"   type="measure"/>
                <field name="overtime_hours"  type="measure"/>
                <field name="overtime_cost"   type="measure"/>
                <field name="total_cost"      type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ══ GRAPH VIEW ════════════════════════════════════════════════════════ -->
    <record id="view_attendance_graph" model="ir.ui.view">
        <field name="name">logistics.attendance.graph</field>
        <field name="model">logistics.attendance</field>
        <field name="arch" type="xml">
            <graph string="Attendance Analysis" type="bar">
                <field name="equipment_id" type="row"/>
                <field name="total_cost"   type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ══ REPORT 1: Equipment Utilization ═══════════════════════════════════ -->
    <record id="action_report_utilization" model="ir.actions.act_window">
        <field name="name">Equipment Utilization</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('status','!=','pending')]</field>
        <field name="context">{'group_by': 'equipment_id'}</field>
    </record>

    <!-- ══ REPORT 2: Cost Summary ═════════════════════════════════════════════ -->
    <record id="action_report_cost" model="ir.actions.act_window">
        <field name="name">Cost Summary</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('status','!=','pending')]</field>
        <field name="context">{'group_by': 'request_id'}</field>
    </record>

    <!-- ══ REPORT 3: Working Hours Analysis ══════════════════════════════════ -->
    <record id="action_report_hours" model="ir.actions.act_window">
        <field name="name">Working Hours Analysis</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('status','in',['present','partial'])]</field>
        <field name="context">{'group_by': 'equipment_id'}</field>
    </record>

    <!-- ══ REPORT 4: Supplier Performance ════════════════════════════════════ -->
    <record id="action_report_supplier" model="ir.actions.act_window">
        <field name="name">Supplier Performance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('status','!=','pending')]</field>
        <field name="context">{'group_by': 'supplier_id'}</field>
    </record>

</odoo>
