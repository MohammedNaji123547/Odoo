<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ ATTENDANCE IMPORT / EXPORT WIZARD ════════════════════════════════ -->
    <record id="view_attendance_import_wizard_form" model="ir.ui.view">
        <field name="name">logistics.attendance.import.wizard.form</field>
        <field name="model">logistics.attendance.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance Excel Import / Export">
                <sheet>
                    <field name="state" invisible="1"/>
                    <notebook>

                        <!-- ── Tab 1: Download ── -->
                        <page string="Download Template" invisible="state == 'done'">
                            <div style="background:#e8f4fd;border-left:4px solid #1F4E79;
                                        padding:10px 14px;margin-bottom:16px;border-radius:3px;">
                                <strong>Step 1:</strong> Set filters below, then click
                                <em>Download Template</em> to get an Excel file pre-filled
                                with all <strong>pending</strong> attendance records.
                                Fill in the Status, Actual Qty, Working Hours, and Remarks
                                columns, then come back to the <em>Upload &amp; Import</em> tab.
                            </div>
                            <group>
                                <group string="Date Range">
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                </group>
                                <group string="Optional Filter">
                                    <field name="request_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Tab 2: Upload ── -->
                        <page string="Upload &amp; Import" invisible="state == 'done'">
                            <div style="background:#fff3cd;border-left:4px solid #ffc107;
                                        padding:10px 14px;margin-bottom:16px;border-radius:3px;">
                                <strong>Step 2:</strong> Upload the filled Excel template here.
                                Only rows with Status = <em>present</em>, <em>partial</em>,
                                or <em>absent</em> will be processed. Do not modify the ID column.
                            </div>
                            <group>
                                <field name="import_file"
                                       filename="import_filename"
                                       widget="binary"
                                       string="Excel File (.xlsx)"/>
                                <field name="import_filename" invisible="1"/>
                            </group>
                        </page>

                        <!-- ── Tab 3: Result ── -->
                        <page string="Import Result" invisible="state != 'done'">
                            <field name="result_message" readonly="1" nolabel="1"
                                   style="font-family:monospace;white-space:pre-wrap;
                                          font-size:13px;padding:8px;"/>
                        </page>

                    </notebook>
                </sheet>
                <footer>
                    <button name="action_download_template"
                            string="Download Template"
                            type="object" class="btn-primary"
                            invisible="state == 'done'"/>
                    <button name="action_import"
                            string="Import Attendance"
                            type="object" class="btn-primary"
                            invisible="state == 'done'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard (appears in Action menu of the attendance list) -->
    <record id="action_attendance_import_wizard" model="ir.actions.act_window">
        <field name="name">Import / Export Attendance</field>
        <field name="res_model">logistics.attendance.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_logistics_attendance"/>
    </record>

    <!-- ══ BULK CONFIRM WIZARD ═══════════════════════════════════════════════ -->
    <record id="view_bulk_confirm_wizard_form" model="ir.ui.view">
        <field name="name">logistics.bulk.confirm.wizard.form</field>
        <field name="model">logistics.bulk.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm All Today's Attendance">
                <sheet>
                    <div style="background:#fff3cd;border:1px solid #ffc107;border-radius:4px;
                                padding:12px 16px;margin-bottom:16px;">
                        <strong>Bulk Confirmation</strong> —
                        This will mark <strong><field name="record_count" readonly="1"/></strong>
                        selected attendance record(s) as
                        <strong>Present</strong>, with Actual Qty = Planned Qty and
                        Working Hours as set below.
                    </div>
                    <group>
                        <field name="working_hours"
                               help="Working hours to apply to all selected records. Default is 10 (standard day)."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm Attendance"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ══ ATTENDANCE FORM ═══════════════════════════════════════════════════ -->
    <record id="view_logistics_attendance_form" model="ir.ui.view">
        <field name="name">logistics.attendance.form</field>
        <field name="model">logistics.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance Record">
                <header>
                    <button name="action_confirm_present" string="Confirm Present (Standard)"
                            type="object" class="btn-primary"
                            invisible="status != 'pending'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,present,partial,absent"/>
                </header>
                <sheet>
                    <group>
                        <group string="Reference">
                            <field name="request_id" readonly="1"/>
                            <field name="equipment_id" readonly="1"/>
                            <field name="supplier_id" readonly="1"/>
                            <field name="attendance_date" readonly="1"/>
                            <field name="planned_qty" readonly="1"/>
                            <field name="daily_rate" readonly="1"/>
                        </group>
                        <group string="Actual Attendance">
                            <field name="status"/>
                            <field name="actual_qty"
                                   invisible="status == 'absent'"/>
                            <field name="working_hours"
                                   invisible="status == 'absent'"/>
                            <field name="remarks"/>
                        </group>
                    </group>
                    <group string="Cost Calculation" invisible="status in ('pending', 'absent')">
                        <group>
                            <field name="hourly_rate" readonly="1"/>
                            <field name="overtime_hours" readonly="1"/>
                            <field name="overtime_cost" readonly="1"/>
                        </group>
                        <group>
                            <field name="daily_cost" readonly="1" string="Daily Cost (per unit)"/>
                            <field name="total_cost" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══ ATTENDANCE TREE (full) ════════════════════════════════════════════ -->
    <record id="view_logistics_attendance_list" model="ir.ui.view">
        <field name="name">logistics.attendance.list</field>
        <field name="model">logistics.attendance</field>
        <field name="arch" type="xml">
            <tree string="Attendance Records"
                  decoration-success="status == 'present'"
                  decoration-warning="status == 'partial'"
                  decoration-danger="status == 'absent'"
                  decoration-muted="status == 'pending'">
                <field name="attendance_date"/>
                <field name="request_id"/>
                <field name="equipment_id"/>
                <field name="supplier_id"/>
                <field name="planned_qty" string="Planned"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'present'"
                       decoration-warning="status == 'partial'"
                       decoration-danger="status == 'absent'"
                       decoration-muted="status == 'pending'"/>
                <field name="actual_qty" string="Actual"/>
                <field name="working_hours" string="Hours"/>
                <field name="overtime_hours" string="OT Hours" optional="show"/>
                <field name="daily_cost" string="Daily Cost" optional="show"/>
                <field name="total_cost" string="Total Cost" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="remarks" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ══ ATTENDANCE SEARCH ══════════════════════════════════════════════════ -->
    <record id="view_logistics_attendance_search" model="ir.ui.view">
        <field name="name">logistics.attendance.search</field>
        <field name="model">logistics.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="request_id"/>
                <field name="equipment_id"/>
                <field name="supplier_id"/>
                <field name="attendance_date"/>
                <separator/>
                <filter name="pending"  string="Pending"
                        domain="[('status','=','pending')]"/>
                <filter name="today"    string="Today"
                        domain="[('attendance_date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="present"  string="Present"
                        domain="[('status','=','present')]"/>
                <filter name="partial"  string="Partial"
                        domain="[('status','=','partial')]"/>
                <filter name="absent"   string="Absent"
                        domain="[('status','=','absent')]"/>
                <filter name="missing"  string="Missing (Pending + Past)"
                        domain="[('status','=','pending'),('attendance_date','&lt;',context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="by_date"      string="Date"
                            context="{'group_by': 'attendance_date'}"/>
                    <filter name="by_equipment" string="Equipment"
                            context="{'group_by': 'equipment_id'}"/>
                    <filter name="by_supplier"  string="Supplier"
                            context="{'group_by': 'supplier_id'}"/>
                    <filter name="by_request"   string="Request"
                            context="{'group_by': 'request_id'}"/>
                    <filter name="by_status"    string="Status"
                            context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ DASHBOARD ACTIONS ═════════════════════════════════════════════════ -->
    <record id="action_attendance_all" model="ir.actions.act_window">
        <field name="name">All Attendance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_logistics_attendance_search"/>
    </record>

    <record id="action_attendance_pending" model="ir.actions.act_window">
        <field name="name">Pending Attendance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_logistics_attendance_search"/>
        <field name="domain">[('status','=','pending')]</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <record id="action_attendance_today" model="ir.actions.act_window">
        <field name="name">Today's Attendance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_logistics_attendance_search"/>
        <field name="domain">[('attendance_date','=',context_today().strftime('%Y-%m-%d'))]</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <record id="action_attendance_missing" model="ir.actions.act_window">
        <field name="name">Missing Attendance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_logistics_attendance_search"/>
        <field name="domain">[('status','=','pending'),('attendance_date','&lt;',context_today().strftime('%Y-%m-%d'))]</field>
    </record>

    <record id="action_attendance_completed" model="ir.actions.act_window">
        <field name="name">Completed Attendance</field>
        <field name="res_model">logistics.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_logistics_attendance_search"/>
        <field name="domain">[('status','in',['present','partial','absent'])]</field>
    </record>

</odoo>
