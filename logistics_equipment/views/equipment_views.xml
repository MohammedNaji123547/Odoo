<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ EQUIPMENT CATEGORY ════════════════════════════════════════════════ -->
    <record id="view_equipment_category_list" model="ir.ui.view">
        <field name="name">logistics.equipment.category.list</field>
        <field name="model">logistics.equipment.category</field>
        <field name="arch" type="xml">
            <tree string="Equipment Categories">
                <field name="name"/>
                <field name="equipment_count" string="Equipment Items"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="view_equipment_category_form" model="ir.ui.view">
        <field name="name">logistics.equipment.category.form</field>
        <field name="model">logistics.equipment.category</field>
        <field name="arch" type="xml">
            <form string="Equipment Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Category Name"/></h1>
                    </div>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Equipment">
                            <field name="equipment_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="standard_daily_rate"/>
                                    <field name="standard_hourly_rate"/>
                                    <field name="default_supplier_id"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'active'"
                                           decoration-danger="status == 'inactive'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_equipment_category" model="ir.actions.act_window">
        <field name="name">Equipment Categories</field>
        <field name="res_model">logistics.equipment.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ══ EQUIPMENT MASTER LIST ══════════════════════════════════════════════ -->
    <record id="view_equipment_list" model="ir.ui.view">
        <field name="name">logistics.equipment.list</field>
        <field name="model">logistics.equipment</field>
        <field name="arch" type="xml">
            <tree string="Equipment Master List"
                  decoration-muted="status == 'inactive'">
                <field name="name"/>
                <field name="category_id"/>
                <field name="standard_daily_rate" string="Daily Rate"/>
                <field name="standard_hourly_rate" string="Hourly Rate"/>
                <field name="default_supplier_id"/>
                <field name="currency_id" invisible="1"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <record id="view_equipment_form" model="ir.ui.view">
        <field name="name">logistics.equipment.form</field>
        <field name="model">logistics.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipment">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Equipment Name"/></h1>
                    </div>
                    <group>
                        <group string="Equipment Details">
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="status" widget="radio" options="{'horizontal': True}"/>
                        </group>
                        <group string="Rates &amp; Supplier">
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="standard_daily_rate"/>
                            <field name="standard_hourly_rate" readonly="1"/>
                            <field name="default_supplier_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_equipment_search" model="ir.ui.view">
        <field name="name">logistics.equipment.search</field>
        <field name="model">logistics.equipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <field name="default_supplier_id"/>
                <filter name="active" string="Active" domain="[('status','=','active')]"/>
                <filter name="inactive" string="Inactive" domain="[('status','=','inactive')]"/>
                <group expand="0" string="Group By">
                    <filter name="by_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="by_supplier" string="Default Supplier"
                            context="{'group_by': 'default_supplier_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_equipment" model="ir.actions.act_window">
        <field name="name">Equipment Master List</field>
        <field name="res_model">logistics.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_equipment_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
